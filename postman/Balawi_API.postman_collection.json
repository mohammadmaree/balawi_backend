{
  "info": {
    "name": "Balawi Backend API",
    "description": "Customer Management API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        },
        "description": "Check if the API server is running"
      }
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"]
            },
            "description": "Get all customers without any filters"
          }
        },
        {
          "name": "Get All Customers (with Pagination)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                }
              ]
            },
            "description": "Get customers with pagination"
          }
        },
        {
          "name": "Search Customers by Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers?search=محمد",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"],
              "query": [
                {
                  "key": "search",
                  "value": "محمد",
                  "description": "Search term (partial match on fullName)"
                }
              ]
            },
            "description": "Search customers by name (partial match, case-insensitive)"
          }
        },
        {
          "name": "Filter Customers by First Letter",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers?letter=م",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"],
              "query": [
                {
                  "key": "letter",
                  "value": "م",
                  "description": "Filter by first letter of name"
                }
              ]
            },
            "description": "Filter customers whose name starts with a specific letter"
          }
        },
        {
          "name": "Get Customers (Combined Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers?search=أحمد&letter=أ&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"],
              "query": [
                {
                  "key": "search",
                  "value": "أحمد",
                  "description": "Search term"
                },
                {
                  "key": "letter",
                  "value": "أ",
                  "description": "First letter filter"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                }
              ]
            },
            "description": "Get customers with search, letter filter, and pagination combined"
          }
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "CUSTOMER_ID_HERE",
                  "description": "MongoDB ObjectId of the customer"
                }
              ]
            },
            "description": "Get a single customer by their ID"
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"محمد أحمد\",\n  \"phoneNumber\": \"0599123456\",\n  \"height\": 175,\n  \"width\": 80,\n  \"type\": \"regular\",\n  \"notes\": \"عميل جديد\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"]
            },
            "description": "Create a new customer. Required fields: fullName, phoneNumber"
          }
        },
        {
          "name": "Create Customer (Minimal)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"علي حسن\",\n  \"phoneNumber\": \"0598765432\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers"]
            },
            "description": "Create a new customer with only required fields"
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"محمد أحمد المحدث\",\n  \"phoneNumber\": \"0599999999\",\n  \"height\": 180,\n  \"width\": 85,\n  \"type\": \"vip\",\n  \"notes\": \"تم تحديث البيانات\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "CUSTOMER_ID_HERE",
                  "description": "MongoDB ObjectId of the customer to update"
                }
              ]
            },
            "description": "Update an existing customer. All fields are optional."
          }
        },
        {
          "name": "Update Customer (Partial)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"ملاحظة جديدة فقط\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "CUSTOMER_ID_HERE",
                  "description": "MongoDB ObjectId of the customer to update"
                }
              ]
            },
            "description": "Update only specific fields of a customer"
          }
        },
        {
          "name": "Delete Customer",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/customers/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "customers", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "CUSTOMER_ID_HERE",
                  "description": "MongoDB ObjectId of the customer to delete"
                }
              ]
            },
            "description": "Delete a customer by ID"
          }
        }
      ]
    }
  ]
}
